{
  "manifest_version": 3,
  "name": "GlassTAB",
  "version": "1.2",
  "description": "A customizable, high-performance new tab extension with clean and fast glassmorphism design :)",
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "chrome_settings_overrides": {
    "homepage": "newtab.html"
  },
  "icons": {
    "16": "static/icon-16.png",
    "48": "static/icon-48.png",
    "64": "static/icon-64.png",
    "128": "static/icon-128.png"
  },
  "permissions": [
    "history",
    "storage"
  ],
  "host_permissions": [
    "*://suggestqueries.google.com/*",
    "*://api.open-meteo.com/*",
    "*://geocoding-api.open-meteo.com/*",
    "*://duckduckgo.com/*",
    "*://www.google.com/s2/favicons*"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "nemik_firefox@custom.extension",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
